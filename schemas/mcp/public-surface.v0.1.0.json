  "resources": [
    {
      "name": "document",
      "uri_template": "graphrag://document/{document_id}",
      "status": "frozen"
    },
    {
      "name": "chunk",
      "uri_template": "graphrag://chunk/{chunk_id}",
      "status": "frozen"
    },
    {
      "name": "entity",
      "uri_template": "graphrag://entity/{entity_id}",
      "status": "frozen"
    },
    {
      "name": "retrieval",
      "uri_template": "graphrag://retrieval/{retrieval_id}",
      "status": "frozen"
