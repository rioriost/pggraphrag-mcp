{
  "version": "0.1.0",
  "protocol": "remote-mcp-http",
  "http_path": "/mcp",
  "auth": {
    "type": "bearer-forward-auth",
    "forwarded_identity_headers": [
      "x-auth-mode",
      "x-auth-user",
      "x-authenticated-identity",
      "x-forwarded-authenticated-method",
      "x-forwarded-authenticated-uri",
