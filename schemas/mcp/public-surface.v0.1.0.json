      "status": "frozen"
    },
    {
      "name": "graph_status",
      "category": "ops",
      "status": "frozen"
    },
    {
      "name": "document_ingest",
      "category": "ingestion",
      "status": "frozen"
    },
    {
      "name": "document_reingest",
      "category": "ingestion",
      "status": "frozen"
    },
    {
      "name": "document_delete",
      "category": "ingestion",
      "status": "frozen"
    },
    {
      "name": "graph_refresh",
      "category": "ops",
      "status": "frozen"
    },
    {
      "name": "retrieve_naive",
      "category": "retrieval",
      "status": "frozen"
    },
    {
      "name": "entity_search",
      "category": "retrieval",
      "status": "frozen"
    },
    {
      "name": "entity_expand",
      "category": "retrieval",
      "status": "frozen"
    },
    {
      "name": "retrieve_local_graph",
      "category": "retrieval",
      "status": "frozen"
    },
    {
      "name": "retrieve_hybrid",
      "category": "retrieval",
      "status": "frozen"
    },
    {
      "name": "source_trace",
      "category": "retrieval",
      "status": "frozen"
    }
