# Application
PGGRAPHRAG_MCP_APP_NAME=pggraphrag-mcp
PGGRAPHRAG_MCP_APP_VERSION=0.1.0
PGGRAPHRAG_MCP_ENV=production
PGGRAPHRAG_MCP_HTTP_HOST=0.0.0.0
PGGRAPHRAG_MCP_HTTP_PORT=8080
PGGRAPHRAG_MCP_HTTP_PATH=/mcp
PGGRAPHRAG_MCP_LOG_LEVEL=INFO
PGGRAPHRAG_MCP_ENABLE_DEBUG_ENDPOINTS=false

# Authentication
PGGRAPHRAG_MCP_SMALL_AUTH_TOKEN=replace-with-a-long-random-token
PGGRAPHRAG_MCP_AUTH_HEADER_NAME=X-Authenticated-Identity
PGGRAPHRAG_MCP_AUTH_IDENTITY=production-client

# Database
PGGRAPHRAG_MCP_DATABASE_HOST=pggraphrag-db
PGGRAPHRAG_MCP_DATABASE_PORT=5432
PGGRAPHRAG_MCP_DATABASE_NAME=pggraphrag
PGGRAPHRAG_MCP_DATABASE_USER=pggraphrag_app
PGGRAPHRAG_MCP_DATABASE_PASSWORD=replace-with-strong-password
PGGRAPHRAG_MCP_DATABASE_URL=postgresql://pggraphrag_app:replace-with-strong-password@pggraphrag-db:5432/pggraphrag
PGGRAPHRAG_MCP_DATABASE_MIGRATION_URL=postgresql://pggraphrag_migrator:replace-with-separate-strong-password@pggraphrag-db:5432/pggraphrag
PGGRAPHRAG_MCP_AGE_GRAPH_NAME=pggraphrag_memory

# Embeddings
PGGRAPHRAG_MCP_EMBEDDING_PROVIDER=openai
PGGRAPHRAG_MCP_EMBEDDING_MODEL=text-embedding-3-small
PGGRAPHRAG_MCP_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=replace-with-provider-api-key

# Retrieval limits
PGGRAPHRAG_MCP_MAX_VECTOR_CANDIDATES=30
PGGRAPHRAG_MCP_MAX_GRAPH_HOPS=2
PGGRAPHRAG_MCP_MAX_RETURN_CHUNKS=12
PGGRAPHRAG_MCP_MAX_RETURN_ENTITIES=20

# Proxy / TLS
PGGRAPHRAG_MCP_PUBLIC_BASE_URL=https://localhost:8443
PGGRAPHRAG_MCP_PROXY_PORT=8443
PGGRAPHRAG_MCP_TLS_CERT_FILE=/certs/dev.crt
PGGRAPHRAG_MCP_TLS_KEY_FILE=/certs/dev.key

# Docker Compose project resources
COMPOSE_PROJECT_NAME=pggraphrag-mcp
PGGRAPHRAG_DB_VOLUME=pggraphrag_db_data
PGGRAPHRAG_TRAEFIK_CERTS_VOLUME=pggraphrag_traefik_certs
PGGRAPHRAG_EDGE_NETWORK=pggraphrag_edge_net
PGGRAPHRAG_APP_NETWORK=pggraphrag_app_net
