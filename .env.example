# Core application settings
PGGRAPHRAG_MCP_APP_NAME=pggraphrag-mcp
PGGRAPHRAG_MCP_APP_VERSION=0.1.0
PGGRAPHRAG_MCP_ENV=local
PGGRAPHRAG_MCP_HTTP_HOST=0.0.0.0
PGGRAPHRAG_MCP_HTTP_PORT=8080
PGGRAPHRAG_MCP_HTTP_PATH=/mcp
PGGRAPHRAG_MCP_ENABLE_DEBUG_ENDPOINTS=true
PGGRAPHRAG_MCP_LOG_LEVEL=INFO

# Auth gateway
PGGRAPHRAG_MCP_SMALL_AUTH_TOKEN=change-me-local-token
AUTH_SMALL_BEARER_TOKEN=change-me-local-token
AUTH_SMALL_USER=local-dev
AUTH_SMALL_MODE=static-token

# Proxy / TLS
PGGRAPHRAG_MCP_TLS_CERT_FILE=/certs/dev.crt
PGGRAPHRAG_MCP_TLS_KEY_FILE=/certs/dev.key
PGGRAPHRAG_MCP_PROXY_PORT=8443
PGGRAPHRAG_MCP_PUBLIC_BASE_URL=https://localhost:8443
PGGRAPHRAG_MCP_AUTH_HEADER_NAME=X-Authenticated-Identity
PGGRAPHRAG_MCP_AUTH_IDENTITY=local-client

# Database
PGGRAPHRAG_MCP_DB_NAME=pggraphrag
PGGRAPHRAG_MCP_DB_USER=pggraphrag_app
PGGRAPHRAG_MCP_DB_PASSWORD=change-me-db-password
PGGRAPHRAG_MCP_DB_HOST=pggraphrag-db
PGGRAPHRAG_MCP_DB_PORT=5432
PGGRAPHRAG_MCP_DATABASE_URL=postgresql://pggraphrag_app:change-me-db-password@pggraphrag-db:5432/pggraphrag
PGGRAPHRAG_MCP_AGE_GRAPH_NAME=pggraphrag_memory

# Embeddings
PGGRAPHRAG_MCP_EMBEDDING_PROVIDER=openai
PGGRAPHRAG_MCP_EMBEDDING_MODEL=text-embedding-3-small
PGGRAPHRAG_MCP_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=

# Retrieval / safety limits
PGGRAPHRAG_MCP_MAX_VECTOR_CANDIDATES=30
PGGRAPHRAG_MCP_MAX_GRAPH_HOPS=2
PGGRAPHRAG_MCP_MAX_RETURN_CHUNKS=12
PGGRAPHRAG_MCP_MAX_RETURN_ENTITIES=20

# Compose / container image names
COMPOSE_PROJECT_NAME=pggraphrag_mcp
PGGRAPHRAG_MCP_PRIVATE_IMAGE=pggraphrag-mcp-private:local
PGGRAPHRAG_MCP_AUTH_IMAGE=pggraphrag-mcp-auth:local
PGGRAPHRAG_MCP_DB_IMAGE=pggraphrag-db:local
